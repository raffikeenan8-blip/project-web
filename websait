<!DOCTYPE html>
<html lang="id",>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jangkar Web</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #ffffff;
            color: #333;
            overflow-x: hidden;
        }

        /* Sidebar Menu */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 250px;
            height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            z-index: 1000;
            transition: transform 0.3s ease;
        }

        .logo {
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }

        .logo h1 {
            color: white;
            font-size: 24px;
            font-weight: bold;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .nav-menu {
            list-style: none;
            padding: 20px 0;
        }

        .nav-menu li {
            margin: 5px 0;
        }

        .nav-menu a {
            display: block;
            padding: 15px 25px;
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-menu a:hover, .nav-menu a.active {
            background: rgba(255,255,255,0.2);
            color: white;
            transform: translateX(10px);
        }

        .nav-menu a::before {
            content: '';
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            width: 6px;
            height: 6px;
            background: white;
            border-radius: 50%;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .nav-menu a:hover::before, .nav-menu a.active::before {
            opacity: 1;
        }

        /* Main Content */
        .main-content {
            margin-left: 250px;
            padding: 20px;
            min-height: 100vh;
        }

        /* Animasi Titik Jatuh */
        .falling-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .dot {
            position: absolute;
            background: rgba(102, 126, 234, 0.6);
            border-radius: 50%;
            animation: fall linear infinite;
        }

        @keyframes fall {
            0% {
                transform: translateY(-100vh) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 40px;
            position: relative;
            z-index: 10;
        }

        .header h2 {
            font-size: 2.5em;
            color: #333;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        /* News Container */
        .news-container {
            display: flex;
            gap: 30px;
            margin-bottom: 50px;
            position: relative;
            z-index: 10;
        }

        .news-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            flex: 1;
            transition: all 0.3s ease;
            border: 1px solid rgba(102, 126, 234, 0.2);
            position: relative;
            overflow: hidden;
        }

        .news-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }

        .news-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.15);
        }

        .news-emoji {
            font-size: 3em;
            display: block;
            text-align: center;
            margin-bottom: 20px;
        }

        .news-title {
            font-size: 1.5em;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
            line-height: 1.3;
        }

        .news-content {
            line-height: 1.6;
            color: #666;
            font-size: 1.1em;
        }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-top: 50px;
        }

        .page-info {
            font-size: 1.2em;
            color: #666;
            font-weight: 500;
        }

        .next-btn {
            background: linear-gradient(135deg, #525d62 0%, #764ba2 100%);
            color: rgb(31, 40, 167);
            border: none;
            width: 60px;
            height: 40px;
            border-radius: 50%;
            font-size: 24px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }

        .next-btn:hover {
            transform: scale(1.1) rotate(20deg);
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.6);
        }

        /* Page Content */
        .page-content {
            display: none;
            animation: fadeIn 0.5s ease;
        }

        .page-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            
            .main-content {
                margin-left: 0;
            }
            
            .news-container {
                flex-direction: column;
            }
        }

        /* History, Recommended, Storage Pages */
        .history-page, .recommended-page, .storage-page {
            padding: 40px 20px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }

        .empty-state h3 {
            font-size: 1.5em;
            margin-bottom: 10px;
            color: #333;
        }
    </style>
</head>
<body>
    <!-- Sidebar Menu -->
    <div class="sidebar">
        <div class="logo">
            <h1>⚓ Jangkar Web</h1>
        </div>
        <ul class="nav-menu">
            <li><a href="#" class="nav-link active" data-page="home">🏠 Home</a></li>
            <li><a href="#" class="nav-link" data-page="history">📜 History</a></li>
            <li><a href="#" class="nav-link" data-page="recommended">⭐ Recommended</a></li>
            <li><a href="#" class="nav-link" data-page="storage">💾 Penyimpanan</a></li>
        </ul>
    </div>

    <!-- Falling Dots Animation -->
    <div class="falling-dots" id="fallingDots"></div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Home Page -->
        <div id="home" class="page-content active">
            <div class="header">
                <h2>Berita Terkini</h2>
                <p>Dapatkan update terbaru setiap hari</p>
            </div>

            <div class="news-container" id="newsContainer">
                <!-- News cards will be generated by JavaScript -->
            </div>

            <div class="pagination">
                <span class="page-info" id="pageInfo">Halaman 1 dari 3</span>
                <button class="next-btn" onclick="nextPage()">➤</button>
                <button class="back btn" onclick="backpage"()></button>
            </div>
        </div>

        <!-- History Page -->
        <div id="history" class="page-content history-page">
            <div class="empty-state">
                <h3>📜 Riwayat Browsing</h3>
                <p>Riwayat pencarian di sini</p>
            </div>
        </div>

        <!-- Recommended Page -->
        <div id="recommended" class="page-content recommended-page">
            <div class="empty-state">
                <h3>⭐ Berita Recommended</h3>
                <p>Berita recommended akan muncul di sini berdasarkan preferensi Anda.</p>
            </div>
        </div>

        <!-- Storage Page -->
        <div id="storage" class="page-content storage-page">
            <div class="empty-state">
                <h3>💾 Penyimpanan</h3>
                <p>simpen sini ntar baca lagi.</p>
            </div>
        </div>
    </div>

    <script>
        // News Data
        const newsData = [
            {
                  title: "isu terbaru terkait kenaikan BBM di Indonesia (2026)",    
                  content: "Pemerintah belum selalu menaikkan harga secara resmi, tetapi ada penyesuaian harga BBM non-subsidi (seperti Pertamax, Pertamax Turbo, dll) yang mengikuti harga minyak dunia. Harga BBM subsidi seperti Pertalite dan Solar masih dijaga, namun terus menjadi beban besar dalam anggaran negara. Saat ini, yang paling sering terjadi adalah penyesuaian harga BBM non-subsidi, sementara BBM subsidi belum tentu naik, tetapi tetap dalam pengawasan ketat dan bisa berubah tergantung kondisi ekonomi global,"
                
                
            }    
            
        ];

        let currentPage = 0;
        const itemsPerPage = 3;
        let newsPerPage = [];

        // Initialize
        function init() {
            createFallingDots();
            generateNewsPages();
            renderNewsPage();
        }

        // Create falling dots animation
        function createFallingDots() {
            const container = document.getElementById('fallingDots');
            for (let i = 0; i < 50; i++) {
                const dot = document.createElement('div');
                dot.className = 'dot';
                dot.style.left = Math.random() * 100 + '%';
                dot.style.width = Math.random() * 6 + 4 + 'px';
                dot.style.height = dot.style.width;
                dot.style.animationDuration = (Math.random() * 3 + 2) + 's';
                dot.style.animationDelay = Math.random() * 3 + 's';
                container.appendChild(dot);
            }
        }

        // Generate news pages
        function generateNewsPages() {
            newsPerPage = [];
            for (let i = 0; i < newsData.length; i += itemsPerPage) {
                newsPerPage.push(newsData.slice(i, i + itemsPerPage));
            }
        }

        // Render current news page
        function renderNewsPage() {
            const container = document.getElementById('newsContainer');
            const pageInfo = document.getElementById('pageInfo');
            
            container.innerHTML = '';
            const currentNews = newsPerPage[currentPage] || [];
            
            currentNews.forEach(news => {
                const card = document.createElement('div');
                card.className = 'news-card';
                card.innerHTML = `
                    <span class="news-emoji">${news.emoji}</span>
                    <div class="news-title">${news.title}</div>
                    <div class="news-content">${news.content}</div>
                `;
                container.appendChild(card);
            });

            pageInfo.textContent = `Halaman ${currentPage + 1} dari ${newsPerPage.length}`;
        }

        // Next page function
        function nextPage() {
            if (currentPage < newsPerPage.length - 1) {
                currentPage++;
                renderNewsPage();
            }
        }

        // Navigation menu
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Remove active class
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                document.querySelectorAll('.page-content').forEach(p => p.classList.remove('active'));
                
                // Add active class
                link.classList.add('active');
                document.getElementById(link.dataset.page).classList.add('active');
            });
        });

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' && document.getElementById('home').classList.contains('active')) {
                nextPage();
            }
        });

        // Initialize app
        init();
    </script>
</body>
</html>
