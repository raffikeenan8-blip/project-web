<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Las Vegas Casino - BlackJack Deluxe</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a0033 50%, #2d004d 100%);
            color: #fff;
            font-family: 'Orbitron', monospace;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* Animasi bintang */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(2px 2px at 20px 30px, #eee, transparent),
                radial-gradient(2px 2px at 40px 70px, #fff, transparent),
                radial-gradient(1px 1px at 90px 40px, #fff, transparent),
                radial-gradient(1px 1px at 130px 80px, #ddd, transparent);
            background-repeat: repeat;
            background-size: 200px 100px;
            animation: sparkle 20s linear infinite;
            z-index: 1;
        }

        @keyframes sparkle {
            0% { transform: translateY(0px) rotate(0deg); }
            100% { transform: translateY(-100px) rotate(360deg); }
        }

        /* Login Page */
        .login-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            z-index: 10;
            position: relative;
        }

        .casino-girl {
            width: 300px;
            height: 400px;
            background: linear-gradient(45deg, #ff00ff, #8a2be2, #ff1493);
            border-radius: 50% 20% 50% 20%;
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 50px #ff00ff;
            animation: glow 2s ease-in-out infinite alternate;
        }

        .casino-girl::before {
            content: '🎰';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 80px;
            animation: bounce 1s infinite;
        }

        @keyframes glow {
            from { box-shadow: 0 0 20px #ff00ff; }
            to { box-shadow: 0 0 60px #ff00ff, 0 0 100px #8a2be2; }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translate(-50%, -50%) translateY(0); }
            40% { transform: translate(-50%, -50%) translateY(-20px); }
            60% { transform: translate(-50%, -50%) translateY(-10px); }
        }

        .welcome-text {
            font-size: 4rem;
            font-weight: 900;
            text-shadow: 0 0 30px #ff00ff;
            margin-bottom: 50px;
            animation: neon 2s ease-in-out infinite alternate;
            letter-spacing: 5px;
        }

        @keyframes neon {
            from { text-shadow: 0 0 20px #ff00ff, 0 0 30px #ff00ff, 0 0 40px #ff00ff; }
            to { text-shadow: 0 0 10px #8a2be2, 0 0 20px #8a2be2, 0 0 30px #8a2be2, 0 0 40px #8a2be2; }
        }

        .password-container {
            position: relative;
            margin-bottom: 30px;
        }

        .password-input {
            background: rgba(0,0,0,0.8);
            border: 2px solid #ff00ff;
            border-radius: 50px;
            padding: 20px 60px 20px 25px;
            font-size: 1.5rem;
            font-family: 'Orbitron', monospace;
            color: #fff;
            width: 400px;
            outline: none;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(255,0,255,0.3);
        }

        .password-input:focus {
            box-shadow: 0 0 40px #ff00ff;
            border-color: #8a2be2;
            transform: scale(1.05);
        }

        .enter-btn {
            position: absolute;
            right: -10px;
            top: 50%;
            transform: translateY(-50%);
            background: linear-gradient(45deg, #ff00ff, #8a2be2);
            border: none;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            font-size: 1.2rem;
            cursor: pointer;
            color: #fff;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px #ff00ff;
        }

        .enter-btn:hover {
            transform: translateY(-50%) scale(1.1);
            box-shadow: 0 0 40px #ff00ff;
        }

        .error-message {
            color: #ff4444;
            font-size: 1.2rem;
            margin-top: 20px;
            animation: shake 0.5s ease-in-out;
            display: none;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }

        /* Main Game Page */
        .game-container {
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            padding: 20px;
        }

        .balance {
            font-size: 2rem;
            margin-bottom: 30px;
            padding: 15px 30px;
            background: rgba(0,0,0,0.8);
            border: 2px solid #ff00ff;
            border-radius: 50px;
            box-shadow: 0 0 30px rgba(255,0,255,0.5);
        }

        .slot-machine {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            padding: 40px;
            border-radius: 30px;
            border: 3px solid #ff00ff;
            box-shadow: 0 0 60px rgba(255,0,255,0.6);
            margin-bottom: 40px;
            min-width: 500px;
        }

        .slot-display {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
            padding: 30px;
            background: rgba(0,0,0,0.9);
            border-radius: 20px;
            border: 2px solid #8a2be2;
        }

        .slot-reel {
            width: 120px;
            height: 120px;
            background: linear-gradient(45deg, #333, #555);
            border: 4px solid #ff00ff;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: bold;
            box-shadow: 
                inset 0 0 20px rgba(0,0,0,0.5),
                0 0 40px rgba(255,0,255,0.4);
            transition: all 0.5s ease;
        }

        .slot-reel.spinning {
            animation: spin 0.5s ease-in-out;
        }

        @keyframes spin {
            0% { transform: rotateY(0deg) scale(1); }
            50% { transform: rotateY(180deg) scale(1.1); }
            100% { transform: rotateY(360deg) scale(1); }
        }

        .jackpot {
            animation: jackpotGlow 0.5s infinite alternate;
            border-color: #ffd700 !important;
            box-shadow: 0 0 60px #ffd700, inset 0 0 30px #ffd700 !important;
        }

        @keyframes jackpotGlow {
            from { filter: hue-rotate(0deg) brightness(1); }
            to { filter: hue-rotate(60deg) brightness(1.5); }
        }

        .bet-input {
            text-align: center;
            margin-bottom: 30px;
        }

        .bet-input input {
            background: rgba(0,0,0,0.8);
            border: 2px solid #ff00ff;
            border-radius: 25px;
            padding: 15px 25px;
            font-size: 1.3rem;
            font-family: 'Orbitron', monospace;
            color: #fff;
            width: 200px;
            outline: none;
            text-align: center;
        }

        .start-btn {
            background: linear-gradient(45deg, #ff00ff, #8a2be2, #ff1493);
            border: none;
            border-radius: 50px;
            padding: 20px 60px;
            font-size: 1.8rem;
            font-weight: bold;
            font-family: 'Orbitron', monospace;
            color: #fff;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 30px #ff00ff;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .start-btn:hover:not(:disabled) {
            transform: scale(1.1);
            box-shadow: 0 0 50px #ff00ff;
        }

        .start-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .message {
            font-size: 1.5rem;
            margin-top: 20px;
            padding: 15px 30px;
            border-radius: 25px;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .win { background: rgba(0,255,0,0.3); border: 2px solid #00ff00; }
        .lose { background: rgba(255,0,0,0.3); border: 2px solid #ff0000; }
        .jackpot-win { background: rgba(255,215,0,0.4); border: 3px solid #ffd700; animation: pulse 1s infinite; }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(0,0,0,0.7);
            border: 2px solid #ff00ff;
            color: #fff;
            padding: 10px 20px;
            border-radius: 25px;
            cursor: pointer;
            font-family: 'Orbitron', monospace;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #ff00ff;
            box-shadow: 0 0 20px #ff00ff;
        }
    </style>
</head>
<body>
    <!-- Login Page -->
    <div class="login-container" id="loginPage">
        <div class="casino-girl"></div>
        <div class="welcome-text">WELCOME</div>
        <div class="password-container">
            <input type="password" class="password-input" id="passwordInput" placeholder="Masukkan Password VIP..." maxlength="6">
            <button class="enter-btn" onclick="checkPassword()">ENTER</button>
        </div>
        <div class="error-message" id="errorMessage">❌ PASSWORD SALAH!</div>
    </div>

    <!-- Game Page -->
    <div class="game-container" id="gamePage">
        <button class="back-btn" onclick="showLogin()">← KEMBALI</button>
        <div class="balance" id="balance">💰 1,000,000 COINS</div>
        
        <div class="slot-machine">
            <div class="slot-display">
                <div class="slot-reel" id="reel1">7</div>
                <div class="slot-reel" id="reel2">7</div>
                <div class="slot-reel" id="reel3">7</div>
            </div>
            
            <div class="bet-input">
                <input type="number" id="betAmount" min="100" max="100000" value="1000" placeholder="Taruhan (min 100)">
            </div>
            
            <button class="start-btn" id="startBtn" onclick="spinSlot()">🎰 SPIN NOW 🎰</button>
        </div>
        
        <div class="message" id="gameMessage">Taruh taruhan dan SPIN untuk memulai!</div>
    </div>

    <script>
        const PASSWORD = "112990";
        let coins = 1000000;
        let isSpinning = false;

        function checkPassword() {
            const input = document.getElementById('passwordInput').value;
            const errorMsg = document.getElementById('errorMessage');
            
            if (input === PASSWORD) {
                document.getElementById('loginPage').style.display = 'none';
                document.getElementById('gamePage').style.display = 'flex';
                updateBalance();
            } else {
                errorMsg.style.display = 'block';
                document.getElementById('passwordInput').value = '';
                setTimeout(() => {
                    errorMsg.style.display = 'none';
                }, 3000);
            }
        }

        function showLogin() {
            document.getElementById('gamePage').style.display = 'none';
            document.getElementById('loginPage').style.display = 'flex';
            document.getElementById('passwordInput').value = '';
        }

        function updateBalance() {
            document.getElementById('balance').textContent = `💰 ${coins.toLocaleString()} COINS`;
        }

        function spinSlot() {
            if (isSpinning) return;
            
            const bet = parseInt(document.getElementById('betAmount').value);
            if (!bet || bet > coins || bet < 100) {
                showMessage('❌ Taruhan tidak valid atau saldo tidak cukup!', 'lose');
                return;
            }

            isSpinning = true;
            document.getElementById('startBtn').disabled = true;
            coins -= bet;
            updateBalance();

            // Generate random numbers
            const numbers = [];
            for (let i = 0; i < 3; i++) {
                numbers.push(Math.floor(Math.random() * 10));
            }

            // Animate spinning
            const reels = ['reel1', 'reel2', 'reel3'];
            reels.forEach((reelId, index) => {
                const reel = document.getElementById(reelId);
                reel.classList.add('spinning');
                setTimeout(() => {
                    reel.textContent = numbers[index];
                    reel.classList.remove('spinning');
                }, 500);
            });

            setTimeout(() => {
                checkWin(numbers, bet);
                isSpinning = false;
                document.getElementById('startBtn').disabled = false;
            }, 800);
        }

        function checkWin(numbers, bet) {
            const messageEl = document.getElementById('gameMessage');
            const reels = document.querySelectorAll('.slot-reel');
            
            if (numbers[0] === numbers[1] && numbers[1] === numbers[2]) {
                // JACKPOT!
                const multiplier = 2;
                const winnings = bet * multiplier;
                coins += winnings;
                updateBalance();
                
                messageEl.textContent = `🎉 JACKPOT ${numbers[0]}${numbers[1]}${numbers[2]}! MENANG ${winnings.toLocaleString()} COINS! 🎉`;
                messageEl.className = 'message jackpot-win';
                
                reels.forEach(reel => reel.classList.add('jackpot'));
                setTimeout(() => {
                    reels.forEach(reel => reel.classList.remove('jackpot'));
                }, 3000);
            } else {
                messageEl.textContent = `💸 ${numbers[0]}${numbers[1]}${numbers[2]} - KALDID! Kehilangan ${bet.toLocaleString()} coins`;
                messageEl.className = 'message lose';
            }
        }

        function showMessage(text, type) {
            const messageEl = document.getElementById('gameMessage');
            messageEl.textContent = text;
            messageEl.className = `message ${type}`;
        }

        // Enter key support
        document.getElementById('passwordInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                checkPassword();
            }
        });

        // Prevent negative balance
        document.getElementById('betAmount').addEventListener('input', function() {
            if (parseInt(this.value) > coins) {
                this.value = coins;
            }
        });
    </script>
</body>
</html>
